# ---- Woldt Consulting Practice Pulse aggregator: environment ----
# Copy to your host's environment (or a local .env loaded by your shell).

DATA_SOURCE=live                     # live | cal | simulated
PORT=8787                            # most hosts inject their own PORT; the server respects it
ALLOWED_ORIGIN=                      # set to your site origin in prod, e.g. https://woldtconsulting.com

# Cal.com (discovery_calls) — from the Cal.com webhook setup (DR-001)
CAL_WEBHOOK_SECRET=

# HubSpot Free CRM (leads, week_total, engagements) — Private App token, read scopes
HUBSPOT_TOKEN=
HUBSPOT_ENGAGEMENT_STAGE=            # deal-stage id that means "active engagement"

# Plausible (sessions_live, sessions_today)
PLAUSIBLE_API_KEY=
PLAUSIBLE_SITE_ID=                   # your domain, e.g. woldtconsulting.com
PLAUSIBLE_HOST=https://plausible.io  # change only if self-hosting Plausible

# Poll cadences (sane defaults; leave as-is unless needed)
POLL_CRM_MS=300000                   # HubSpot every 5 min (free-tier friendly)
POLL_LIVE_MS=30000                   # Plausible realtime every 30 s
POLL_TODAY_MS=120000                 # Plausible today every 2 min
